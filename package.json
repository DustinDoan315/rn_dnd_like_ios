{
  "name": "react-native-dnd-like-ios",
  "version": "2.0.0",
  "description": "Drag-and-drop sortable grid for React Native, mimicking the iOS home screen rearrange experience",
  "keywords": [
    "react-native",
    "react-native-dnd",
    "react-native-animation",
    "react-native-dnd-like-ios",
    "react-native-drag-and-drop"
  ],
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarryDoan/react-native-dnd-like-ios.git"
  },
  "author": "Harry Doan",
  "license": "ISC",
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "bugs": {
    "url": "https://github.com/HarryDoan/react-native-dnd-like-ios/issues"
  },
  "homepage": "https://github.com/HarryDoan/react-native-dnd-like-ios#readme"
}
